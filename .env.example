# Core app environment
NODE_ENV=
NEXT_PUBLIC_SITE_URL=

# Database — NeonDB (Postgres). Source of truth for leads + structured data.
# See db/migrations/ for schema.
DATABASE_URL=

# Whop integration
WHOP_API_KEY=
NEXT_PUBLIC_WHOP_APP_ID=
NEXT_PUBLIC_WHOP_COMPANY_ID=
NEXT_PUBLIC_WHOP_AGENT_USER_ID=
WHOP_WEBHOOK_SECRET=

# OpenAI & AI services
OPENAI_API_KEY=

# MailerLite integration
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Email — Resend (lead notifications, transactional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
LEAD_NOTIFICATION_EMAIL=
FROM_EMAIL=

# n8n automation (optional). Lead capture continues if n8n fails.
N8N_WEBHOOK_URL=
N8N_LEAD_WEBHOOK_URL=
CRM_WEBHOOK_URL=

# Applied Intelligence diagnostic
LEAD_FORM_SECRET=
IP_HASH_SALT=

# Sanity CMS — blog / topic cluster content
# Leave NEXT_PUBLIC_SANITY_PROJECT_ID empty to run without Sanity (blog shows empty state).
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01
SANITY_API_READ_TOKEN=

# Supabase — only used if auth, storage, or realtime is required.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe payments
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ImageKit CDN
IMAGEKIT_ENDPOINT=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=

# Observability & monitoring
LOG_LEVEL=
SENTRY_DSN=
RELEASE=

# API base URLs
API_BASE_URL=
NEXT_PUBLIC_API_URL=

# ---------------------------------------------------------------
# Wave 1 / dev-mode integration switches.
# These let you run the UI locally without live integration tokens.
# All values are optional; defaults are safe (mock adapters, disabled).
# ---------------------------------------------------------------

# Lead-form provider switch.
#   "mock"   — log to console, return synthetic success (default in dev when RESEND_API_KEY unset)
#   "resend" — POST through the Resend + Neon pipeline (default in production)
LEAD_FORM_PROVIDER=

# Force-disable optional integrations regardless of token presence.
# Useful for browser/Storybook/E2E sessions where you want the
# UI to render the "pending" state instead of attempting a request.
NEXT_PUBLIC_MAILERLITE_DISABLED=
NEXT_PUBLIC_IMAGEKIT_DISABLED=
NEXT_PUBLIC_OPENAI_DISABLED=

# Optional ImageKit hero overlay path. If set, the homepage hero's
# right-pane SVG will composite this image as an aria-hidden overlay.
# Leave empty to ship the pure code-rendered hero.
NEXT_PUBLIC_IK_HERO_OVERLAY=
