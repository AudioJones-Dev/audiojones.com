# Core app environment
NODE_ENV=
NEXT_PUBLIC_SITE_URL=

# Database — NeonDB (Postgres). Source of truth for leads + structured data.
# See db/migrations/ for schema.
DATABASE_URL=

# Whop integration
WHOP_API_KEY=
NEXT_PUBLIC_WHOP_APP_ID=
NEXT_PUBLIC_WHOP_COMPANY_ID=
NEXT_PUBLIC_WHOP_AGENT_USER_ID=
WHOP_WEBHOOK_SECRET=

# OpenAI & AI services
OPENAI_API_KEY=

# MailerLite integration
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# Email — Resend (lead notifications, transactional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
LEAD_NOTIFICATION_EMAIL=
FROM_EMAIL=

# n8n automation (optional). Lead capture continues if n8n fails.
N8N_WEBHOOK_URL=
N8N_LEAD_WEBHOOK_URL=
CRM_WEBHOOK_URL=

# Applied Intelligence diagnostic
LEAD_FORM_SECRET=
IP_HASH_SALT=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_READ_TOKEN=

# Supabase — only used if auth, storage, or realtime is required.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe payments
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ImageKit CDN
IMAGEKIT_ENDPOINT=
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=

# Observability & monitoring
LOG_LEVEL=
SENTRY_DSN=
RELEASE=

# API base URLs
API_BASE_URL=
NEXT_PUBLIC_API_URL=
