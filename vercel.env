# vercel.env — Vercel Environment Variables Setup
#
# Firebase credentials previously lived in this file. They have been removed
# alongside the Firebase migration. See docs/architecture/stack-decision.md.
# Rotate any Firebase service-account keys that were committed to git history.

# ===================================================
# DATABASE — NeonDB (Postgres)
# ===================================================
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# ===================================================
# EMAIL — Resend
# ===================================================
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=
# LEAD_NOTIFICATION_EMAIL=

# ===================================================
# WHOP API CREDENTIALS
# ===================================================
# WHOP_API_KEY=
# WHOP_APP_ID=

# ===================================================
# INSTRUCTIONS:
# ===================================================
# 1. Go to https://vercel.com/<team>/<project>/settings/environment-variables
# 2. Add each variable above with the live value (do NOT commit secrets here).
# 3. See .env.example for the canonical list of supported variables.
