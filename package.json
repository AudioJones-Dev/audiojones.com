{
    "name": "audiojones.com",
    "version": "0.1.0",
    "packageManager": "pnpm@10.30.3",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "pnpm packages:build && next build",
        "start": "next start",
        "lint": "eslint",
        "dx:init": "echo 'Setting up Doppler and environment...' && doppler setup --project ajdigital --config dev; doppler secrets download --no-file --format env > .env.development.local",
        "env:check": "tsx -e \"require('./packages/config/dist/index.js')\" && echo \"\u00e2\u0153\u2026 Environment validation successful\"",
        "prestart": "tsx -e \"require('./packages/config/dist/index.js')\"",
        "packages:build": "pnpm -r --filter='@aj/*' build",
        "packages:dev": "pnpm -r --filter='@aj/*' dev",
        "verify:integrations": "tsx scripts/verify-integrations.ts",
        "imagekit:convert": "node scripts/convert-to-ikimage.js",
        "imagekit:setup": "node scripts/setup-imagekit.js",
        "repo:init": "node tools/repo.js init",
        "repo:link": "node tools/repo.js link",
        "repo:sync": "node tools/repo.js sync",
        "repo:status": "node tools/repo.js status",
        "repo:commit": "node tools/repo.js commit",
        "test-client-data": "tsx tools/create-test-client-data.js",
        "seed:capacity": "tsx scripts/seedCapacitySettings.ts",
        "slo:init": "tsx scripts/initSloCollections.ts",
        "slo:test": "tsx scripts/testSloCredits.ts",
        "slo:credits": "tsx scripts/testSloCredits.ts",
        "backup:init": "tsx scripts/testBackupDR.ts init",
        "backup:test": "tsx scripts/testBackupDR.ts test",
        "backup:dr": "tsx scripts/testBackupDR.ts disaster-recovery",
        "backup:scheduled": "tsx scripts/scheduledBackup.ts",
        "backup:force": "tsx scripts/scheduledBackup.ts --force",
        "backup:report": "tsx scripts/scheduledBackup.ts --report",
        "secrets:init": "tsx scripts/testSecretsRotation.ts init",
        "secrets:test": "tsx scripts/testSecretsRotation.ts test",
        "secrets:metrics": "tsx scripts/testSecretsRotation.ts metrics",
        "secrets:check": "tsx scripts/testSecretsRotation.ts check",
        "secrets:scheduled": "tsx scripts/scheduledSecretsRotation.ts",
        "secrets:force": "tsx scripts/scheduledSecretsRotation.ts --force",
        "secrets:health": "tsx scripts/scheduledSecretsRotation.ts --health-only",
        "multitenant:init": "tsx scripts/testMultiTenant.ts init",
        "multitenant:test": "tsx scripts/testMultiTenant.ts",
        "multitenant:metrics": "tsx scripts/testMultiTenant.ts metrics",
        "lint:api-imports": "eslint \"src/app/api/**/route.ts\"",
        "typecheck": "tsc --noEmit",
        "check:no-firebase": "tsx scripts/check-no-firebase.ts",
        "vercel:patch-win": "powershell -ExecutionPolicy Bypass -File scripts/patch-vercel-next-win.ps1",
        "build:prod": "pnpm vercel:patch-win && npx vercel build --prod",
        "deploy:prod": "pnpm vercel:patch-win && npx vercel --prod"
    },
    "dependencies": {
        "@aj/config": "workspace:*",
        "@aj/whop": "workspace:*",
        "@google-cloud/secret-manager": "^5.6.0",
        "@google-cloud/storage": "^7.17.3",
        "@neondatabase/neon-js": "0.2.0-beta.1",
        "@neondatabase/serverless": "^1.0.0",
        "@supabase/ssr": "^0.6.1",
        "@supabase/supabase-js": "^2.50.0",
        "@whop/sdk": "^0.0.6",
        "clsx": "^2.1.1",
        "discord-interactions": "^4.4.0",
        "imagekit": "^6.0.0",
        "lucide-react": "^0.546.0",
        "next": "16.2.3",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "remark": "^15.0.1",
        "remark-html": "^16.0.1",
        "resend": "^4.6.0",
        "server-only": "^0.0.1",
        "stripe": "^19.1.0",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/node-fetch": "^2.6.13",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "dotenv": "^17.2.3",
        "eslint": "^9",
        "eslint-config-next": "16.0.0",
        "glob": "^11.0.3",
        "jscodeshift": "^17.3.0",
        "node-fetch": "^3.3.2",
        "sharp": "^0.34.4",
        "sharp-cli": "^5.2.0",
        "tailwindcss": "^4",
        "tsx": "^4.20.6",
        "typescript": "^5",
        "vercel": "48.9.0"
    },
    "description": "This repo is initialized from `codex.init.yml`.",
    "main": "index.js",
    "directories": {
        "doc": "docs",
        "test": "test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/AJDIGITALllc/audiojones.com.git"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/AJDIGITALllc/audiojones.com/issues"
    },
    "homepage": "https://github.com/AJDIGITALllc/audiojones.com#readme",
    "pnpm": {
        "overrides": {
            "fast-xml-parser": ">=4.5.4",
            "better-auth": ">=1.4.9",
            "protobufjs": ">=7.5.5",
            "glob": ">=11.1.0",
            "node-forge": ">=1.3.2",
            "jws": ">=4.0.1",
            "tar": ">=7.5.7",
            "fastify": ">=5.7.2",
            "axios": ">=1.13.5",
            "minimatch@9": ">=9.0.7",
            "minimatch@10": ">=10.2.3",
            "flatted": ">=3.4.2",
            "picomatch": ">=4.0.4",
            "path-to-regexp": ">=8.4.0",
            "lodash": ">=4.18.0",
            "@isaacs/brace-expansion": ">=5.0.1",
            "eslint-plugin-react-hooks>zod": "^4.0.0"
        }
    }
}